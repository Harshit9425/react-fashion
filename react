      </div>

      <div className="w-full max-w-md relative z-10 backdrop-blur-2xl bg-black/40 border border-white/10 p-10 lg:p-16 shadow-[0_0_50px_rgba(0,0,0,0.8)] animate-in slide-in-from-right-12 duration-1000 group/form rounded-sm">
