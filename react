        <div className="absolute bottom-[-20%] right-[10%] w-[50vw] h-[50vw] rounded-full bg-indigo-900/30 blur-[120px] mix-blend-screen animate-pulse" style={{ animationDelay: '1s' }}></div>
        <div className="absolute inset-0 bg-gradient-to-r from-black/95 via-black/50 to-black/90 backdrop-blur-[2px]"></div>
      </div>

      <ThreeDBackground />

      <div className="absolute bottom-24 left-12 lg:left-24 z-10 hidden md:block animate-in slide-in-from-bottom-12 duration-[1.5s] ease-out pointer-events-none">
        <h1 className="text-white text-6xl lg:text-8xl serif tracking-[0.15em] uppercase mb-4 transition-all hover:tracking-[0.25em] duration-700 drop-shadow-2xl">
