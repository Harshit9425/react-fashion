function LoginPage({ setCurrentView, showToast, setLoggedInUser }) {
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const [error, setError] = useState(null);
  const [isLoading, setIsLoading] = useState(false);

  const handleLogin = (e) => {
    e.preventDefault();
    setError(null);
    setIsLoading(true);

    setTimeout(() => {
      if (username.trim() && password === 'Test@123') {
        setLoggedInUser(username);
        showToast('Welcome back to the Atelier.');
        setCurrentView('home');
      } else {
        setError('Invalid identifier or security code.');
      }
      setIsLoading(false);
    }, 1200);
  };

  return (
    <div className="min-h-screen relative flex items-center justify-center lg:justify-end bg-black text-white overflow-hidden p-6 lg:p-24">
      <div className="absolute inset-0 z-0 overflow-hidden">
